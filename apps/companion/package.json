{
  "name": "@agentpet/companion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/apps/companion/src/main/main.js",
  "scripts": {
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "watch:main": "tsc -p tsconfig.main.json --watch",
    "watch:preload": "tsc -p tsconfig.preload.json --watch",
    "dev": "vite",
    "start": "electron dist/main/apps/companion/src/main/main.js",
    "start:built": "npm run build && npm run start",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "@agentpet/protocol": "0.1.0",
    "@lottiefiles/dotlottie-react": "^0.18.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.2.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
}
